generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  VOID
  OVERDUE
}

enum SyncStatus {
  SYNCED
  PENDING
  PROCESSING
  CONFLICT
  ERROR
}

enum EventSource {
  INTERNAL
  QBO
}

enum EventStatus {
  PENDING
  PROCESSED
  SKIPPED
  FAILED
}

enum AuditResult {
  SUCCESS
  FAILURE
}

model Invoice {
  id          String        @id @default(cuid())
  customerId  String
  lineItems   Json
  totalAmount Decimal       @db.Decimal(12, 2)
  currency    String        @default("USD")
  status      InvoiceStatus @default(DRAFT)
  dueDate     DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  payments Payment[]
  syncLink SyncLink?

  @@index([customerId])
  @@index([status])
}

model Payment {
  id        String   @id @default(cuid())
  invoiceId String
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("USD")
  paidAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([invoiceId])
}

model SyncLink {
  id                  String     @id @default(cuid())
  internalId          String     @unique
  qboId               String?
  internalUpdatedAt   DateTime
  qboUpdatedAt        DateTime?
  qboSyncToken        String?
  lastSyncedSnapshot  Json?
  syncStatus          SyncStatus @default(PENDING)
  lastSyncedAt        DateTime?
  version             Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  invoice   Invoice  @relation(fields: [internalId], references: [id])
  auditLogs AuditLog[]

  @@index([syncStatus])
  @@index([qboId])
}

model PaymentSyncLink {
  id                String     @id @default(cuid())
  internalId        String     @unique
  qboId             String     @unique
  invoiceInternalId String
  syncStatus        SyncStatus @default(PENDING)
  lastSyncedAt      DateTime?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([syncStatus])
  @@index([invoiceInternalId])
}

model AccountMap {
  id                  String   @id @default(cuid())
  internalAccountCode String   @unique
  qboAccountId        String
  qboAccountName      String
  updatedAt           DateTime @updatedAt
}

model ItemMap {
  id               String   @id @default(cuid())
  internalItemCode String   @unique
  qboItemId        String
  qboItemName      String
  defaultTaxCode   String   @default("NON")
  updatedAt        DateTime @updatedAt
}

model CustomerMap {
  id                 String   @id @default(cuid())
  internalCustomerId String   @unique
  qboCustomerId      String
  qboCustomerName    String
  updatedAt          DateTime @updatedAt
}

model QBOCredentials {
  id                      String   @id @default(cuid())
  encryptedAccessToken    String
  encryptedRefreshToken   String
  expiresAt               DateTime
  refreshTokenExpiresAt   DateTime
  updatedAt               DateTime @updatedAt
}

model EventLog {
  id          String      @id @default(cuid())
  eventId     String      @unique
  source      EventSource
  eventType   String
  payload     Json
  receivedAt  DateTime    @default(now())
  processedAt DateTime?
  status      EventStatus @default(PENDING)

  @@index([status])
  @@index([source, eventType])
}

model AuditLog {
  id            String      @id @default(cuid())
  syncLinkId    String?
  action        String
  sourceEventId String
  beforeState   Json?
  afterState    Json?
  result        AuditResult
  error         String?
  createdAt     DateTime    @default(now())

  syncLink SyncLink? @relation(fields: [syncLinkId], references: [id])

  @@index([syncLinkId])
  @@index([sourceEventId])
}
