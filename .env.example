# Core
NODE_ENV=development
DATABASE_URL=postgresql://invoice_user:invoice_pass@localhost:5432/invoice_sync
PORT=3000

# QBO OAuth
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_REDIRECT_URI=http://localhost:3000/auth/qbo/callback
QB_ENVIRONMENT=sandbox
QB_REALM_ID=
QB_WEBHOOK_VERIFIER_TOKEN=

# Sandbox only — fallback CustomerRef when CustomerMap has no entry; NEVER set in production
QB_DEFAULT_CUSTOMER_ID=     # sandbox only — bypasses CustomerMap lookup
QB_DEFAULT_ITEM_ID=         # sandbox only — used when line items have no internalItemCode

# Token encryption — generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# API auth
API_KEY=

# Frontend URL — where to redirect after QBO OAuth callback
# Dev: http://localhost:5173  |  Production: omit (defaults to /)
FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Sync tuning
RECONCILIATION_INTERVAL_MINUTES=15
SYNC_JOB_MAX_RETRIES=3
QBO_RATE_LIMIT_MAX=2

# Demo deploy only — run BullMQ workers inside the web process when a separate worker service is unavailable.
RUN_WORKERS_IN_WEB=false
