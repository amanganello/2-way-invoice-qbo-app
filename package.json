{
  "name": "invoice-sync-service",
  "version": "0.1.0",
  "description": "Bidirectional invoice sync between internal system and QuickBooks Online",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/server.ts",
    "build:client": "cd client && pnpm install --frozen-lockfile && pnpm build",
    "build": "pnpm build:client && tsc --project tsconfig.json && node scripts/resolve-dist-aliases.mjs",
    "start": "node --env-file=.env dist/server.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "worker": "node --env-file=.env --import tsx/esm src/worker.ts",
    "qbo-auth": "node --env-file=.env --import tsx/esm scripts/qbo-auth.ts",
    "migrate": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.79.2",
    "fastify": "^4.29.1",
    "intuit-oauth": "^4.2.3",
    "ioredis": "^5.11.1",
    "node-cron": "^4.5.0",
    "pino": "^9.5.0",
    "prisma": "^5.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.15.0",
    "eslint-plugin-vitest": "^0.5.4",
    "msw": "^2.14.6",
    "pino-pretty": "^11.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
