{
  "name": "invoice-sync-service",
  "version": "0.1.0",
  "description": "Bidirectional invoice sync between internal system and QuickBooks Online",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^5.22.0",
    "bullmq": "^5.79.2",
    "fastify": "^4.29.1",
    "intuit-oauth": "^4.2.3",
    "ioredis": "^5.11.1",
    "node-cron": "^4.5.0",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9.15.0",
    "eslint-plugin-vitest": "^0.5.4",
    "msw": "^2.14.6",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.8"
  }
}
